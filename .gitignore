# Local .terraform directories
**/.terraform/*

# Terraform state files (NEVER commit these)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Plan output files
*.tfplan
*.tfplan.*

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json
!*.tfvars.example

# Terraform CLI config
.terraformrc
terraform.rc

# Editor / OS junk
.DS_Store
.idea/
.vscode/
*.swp
live-*.yaml
tmp-*

# Diagnostic and portfolio artifacts
[0-9][0-9]-*.json
[0-9][0-9]-*.txt
